{
    "manifest_version": 2,
    "name": "Search Engine Backup",
    "version": "1.0.0",
    "description": "Backup and restore Firefox custom search engine settings via Dropbox",
    "default_locale": "en",
    "permissions": [
        "search",
        "storage",
        "identity",
        "tabs",
        "https://api.dropboxapi.com/*",
        "https://content.dropboxapi.com/*",
        "https://www.dropbox.com/*"
    ],
    "browser_action": {
        "default_popup": "popup.html",
        "default_icon": {
            "48": "icons/icon48.png",
            "96": "icons/icon96.png"
        },
        "default_title": "Search Engine Backup"
    },
    "background": {
        "scripts": [
            "config.js",
            "background.js"
        ]
    },
    "web_accessible_resources": [
        "restore.html",
        "restore.js",
        "backup.html",
        "backup.js"
    ]
}